{
    "name": "etrias/php-toolkit",
    "description": "Common PHP Tooling",
    "license": "MIT",
    "require": {
        "php": "~8.4.21"
    },
    "require-dev": {
        "basis-company/nats": "^1.2.1",
        "doctrine/migrations": "^3.9.7",
        "doctrine/orm": "^3.6.5",
        "guzzlehttp/guzzle": "^7.10.0",
        "monolog/monolog": "^3.10.0",
        "php-http/client-common": "^2.7.3",
        "php-soap/ext-soap-engine": "^1.11.0",
        "phpro/soap-client": "^4.8.0",
        "symfony/cache": "^8.0.10",
        "symfony/console": "^8.0.11",
        "symfony/dependency-injection": "^8.0.10",
        "symfony/doctrine-bridge": "^8.0.9",
        "symfony/doctrine-messenger": "^8.0.6",
        "symfony/event-dispatcher": "^8.0.9",
        "symfony/http-foundation": "^8.0.8",
        "symfony/lock": "^8.0.9",
        "symfony/messenger": "^8.0.11",
        "symfony/property-access": "^8.0.8",
        "symfony/security-bundle": "^8.0.11",
        "symfony/serializer": "^8.0.10",
        "symfony/stopwatch": "^8.0.8",
        "symfony/uid": "^8.0.9",
        "symfony/var-dumper": "^8.0.8"
    },
    "autoload": {
        "psr-4": {
            "Etrias\\PhpToolkit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Etrias\\PhpToolkit\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": false
        },
        "sort-packages": true
    }
}
